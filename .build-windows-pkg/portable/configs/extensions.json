{
  "extensions": [
    {
      "id": "copilot-prompt-injector",
      "name": "Copilot Prompt Injector",
      "type": "Browser Extension",
      "icon": "💻",
      "version": "1.0.0",
      "platforms": ["Chrome", "Firefox", "Edge", "Safari"],
      "description": "Inject prompts into web forms and text areas",
      "features": [
        "One-click prompt injection",
        "Keyboard shortcuts",
        "Auto-formatting",
        "Save favorite prompts",
        "Template management"
      ],
      "permissions": [
        "activeTab",
        "scripting",
        "storage",
        "webRequest"
      ],
      "installUrl": "https://chrome.google.com/webstore"
    },
