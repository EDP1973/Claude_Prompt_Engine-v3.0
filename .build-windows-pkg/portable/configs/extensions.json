  "extensionAPI": {
    "baseUrl": "http://localhost:3000/api/extensions",
    "methods": [
      {
        "name": "injectPrompt",
        "method": "POST",
        "params": ["elementId", "prompt"]
      },
      {
        "name": "recordCall",
        "method": "POST",
        "params": ["callId", "duration"]
      },
      {
        "name": "generateSummary",
        "method": "POST",
        "params": ["content", "length"]
      },
      {
        "name": "getCodeSuggestions",
        "method": "POST",
        "params": ["code", "language"]
      },
      {
        "name": "executeVoiceCommand",
        "method": "POST",
        "params": ["command", "context"]
      }
    ]
  }
}
